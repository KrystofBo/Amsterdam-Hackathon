# Discord Bot Token - get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# OpenClaw Gateway URL (default localhost:18789)
OPENCLAW_URL=http://localhost:18789

# OpenClaw API Token (from openclaw config)
OPENCLAW_TOKEN=your_openclaw_api_token_here

# OpenClaw Agent ID to route messages to (e.g., "synthesizer")
OPENCLAW_AGENT_ID=synthesizer

# Toggle this on to make manage.sh configure the synthesizer agent to use OpenAI.
USE_OPENAI_API=false

# OpenAI settings used when USE_OPENAI_API=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Chat completion target used by the bot.
# Keep this as `openclaw:synthesizer` if you want OpenClaw to own provider/model routing.
OPENCLAW_CHAT_MODEL=openclaw:synthesizer

# Advanced OpenClaw settings.
OPENCLAW_AGENT_MODEL_ALIAS=synthesizer-default
OPENCLAW_AGENT_MODEL=

# Auth profile id used by `./manage.sh configure-openai-auth`
OPENCLAW_OPENAI_PROFILE_ID=openai:manual

# Discord category where project channels are created
PROJECT_CATEGORY=PROJECTS

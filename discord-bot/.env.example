# Discord Bot Token - get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# OpenClaw Gateway URL (default localhost:18789)
OPENCLAW_URL=http://localhost:18789

# OpenClaw API Token (from openclaw config)
OPENCLAW_TOKEN=your_openclaw_api_token_here

# OpenClaw Agent ID to route messages to (e.g., "synthesizer")
OPENCLAW_AGENT_ID=synthesizer
